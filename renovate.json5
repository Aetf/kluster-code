{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'group:pulumi',
  ],
  major: {
    dependencyDashboardApproval: true,
  },
  patch: {
    enabled: false,
  },
  automergeStrategy: 'squash',
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  ignorePaths: [
    'src/crds/**',
  ],
  packageRules: [
    {
      // @pulumi/pulumi 3.253.0 silently dropped 238 resources from
      // `pulumi preview` with no diagnostics due to incompatibility with the
      // pinned @pulumi/kubernetes 3.30 / kubernetesx stack (see commit
      // c93d8d78). Require manual review for any bump until that's verified.
      matchPackageNames: [
        '@pulumi/pulumi',
        '@pulumi/kubernetes',
        '@pulumi/kubernetesx',
      ],
      dependencyDashboardApproval: true,
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      automerge: true,
      groupName: 'dependencies with non-major changes',
      groupSlug: 'deps-non-major',
    },
    {
      matchDepTypes: [
        'devDependencies',
      ],
      automerge: true,
    },
    {
      matchDepTypes: [
        'helm',
        'container',
      ],
      semanticCommitType: 'fix',
      semanticCommitScope: 'apps',
    },
    {
      matchDepTypes: [
        'helm',
        'container',
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      groupName: 'applications with non-major changes',
      groupSlug: 'apps-non-major',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Pulumi\\..+\\.ya?ml$/',
      ],
      matchStrings: [
        'chart:(?<depName>[\\w.-]+):\\s*(?<registryUrl>[\\w.:/-]+):(?<currentValue>[\\w.-]+)',
      ],
      datasourceTemplate: 'helm',
      versioningTemplate: 'helm',
      depTypeTemplate: 'helm',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Pulumi\\..+\\.ya?ml$/',
      ],
      matchStrings: [
        'image:(?<depName>[\\w.-]+):\\s*(?<packageName>[\\w./-]+):(?<currentValue>[\\w.-]+)',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
      depTypeTemplate: 'container',
    },
  ],
}
